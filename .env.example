# Slack tokens — get these from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# Authorized Slack user IDs (comma-separated)
# Find your ID: Slack profile → ⋮ → Copy member ID
# Leave empty to allow all users
AUTHORIZED_USERS=UNITYESH,UPIYUSH

# Working directory — the folder Claude runs from when invoked via Slack.
# This is where your CLAUDE.md lives and where Claude looks for context.
PROJECT_DIR=/Users/luo/Projects/curated-connections

# Claude CLI timeout in seconds (default: 1800 = 30 min)
CLAUDE_TIMEOUT=1800

# HTTP server port (Cloudflare Tunnel points to this)
PORT=3000
